{
  "buildCommand": "mkdir -p dist && echo \"ok\" > dist/index.html && echo \"No build step required for Vercel API Routes\"",
  "devCommand": "npm run dev",
  "installCommand": "npm install --include=dev",
  "rewrites": [
    { "source": "/webhook/event", "destination": "/api/webhook" },
    { "source": "/auth/callback",  "destination": "/api/oauth-callback" }
  ],
  "functions": {
    "api/webhook.ts":           { "maxDuration": 300 },
    "api/oauth-callback.ts":    { "maxDuration": 10  },
    "api/monthly-calendar.ts":  { "maxDuration": 60  }
  },
  "crons": [
    {
      "path": "/api/monthly-calendar",
      "schedule": "0 0 1 * *"
    }
  ]
}
